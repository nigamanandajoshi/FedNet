# =============================================================================
# FedNet — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Model Settings ──────────────────────────────────────────────────────────
MODEL_TYPE=hybrid              # Options: cbc, image, hybrid
IMAGE_SIZE=224
NUM_CLASSES=3

# ── Training ────────────────────────────────────────────────────────────────
BATCH_SIZE=32
LEARNING_RATE=0.001
EPOCHS=50

# ── Federated Learning ─────────────────────────────────────────────────────
FL_ROUNDS=10
LOCAL_EPOCHS=5
AGGREGATION_METHOD=fedavg      # Options: fedavg, weighted
MIN_CLIENTS=2

# ── Layer 1: Audit Artifacts ───────────────────────────────────────────────
ARTIFACT_OUTPUT_DIR=artifacts
HMAC_SIGNING_KEY=              # Set a strong key for production

# ── Layer 2: Solana Attestation ────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WALLET_PATH=            # Path to Solana keypair JSON
SOLANA_NETWORK=devnet          # Options: devnet, mainnet-beta

# ── Layer 3: x402 Monetization ────────────────────────────────────────────
INFERENCE_HOST=0.0.0.0
INFERENCE_PORT=5001
QUERY_PRICE_USDC=0.05
USDC_MINT_ADDRESS=             # USDC mint address on Solana

# ── Blockchain (Local Ethereum) ────────────────────────────────────────────
BLOCKCHAIN_ENABLED=true
BLOCKCHAIN_NETWORK=localhost   # Options: localhost, ganache
ETH_RPC_URL=http://127.0.0.1:8545

# ── API ────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=false

# ── Dashboard ──────────────────────────────────────────────────────────────
DASHBOARD_PORT=5001

# ── Azure ML (Optional) ───────────────────────────────────────────────────
# AZURE_SUBSCRIPTION_ID=
# AZURE_RESOURCE_GROUP=
# AZURE_WORKSPACE_NAME=

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                 # Options: DEBUG, INFO, WARNING, ERROR
